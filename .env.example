# --- Network & signer ---
FAUCET_NETWORK=test                 # main | test
FAUCET_SIGNER_DRIVER=rpc            # rpc | wasm

# RPC signer (default)
FAUCET_RPC_URL=http://localhost:8648/
# FAUCET_RPC_USERNAME=...
# FAUCET_RPC_PASSWORD=...
FAUCET_WALLET_ADDRESS=NQ00 0000 0000 0000 0000 0000 0000 0000 0000
# FAUCET_WALLET_PASSPHRASE=...

# WASM signer (alternative, no external node)
# FAUCET_PRIVATE_KEY=<hex or 24-word seed>
# FAUCET_KEY_PASSPHRASE=at-least-8-chars

# --- Claim amount & rate limits ---
FAUCET_CLAIM_AMOUNT_LUNA=100000     # 1 NIM = 100_000 luna
FAUCET_RATE_LIMIT_PER_MINUTE=30
FAUCET_RATE_LIMIT_PER_IP_PER_DAY=5

# --- Captcha (pick one; all optional) ---
# FAUCET_TURNSTILE_SITE_KEY=...
# FAUCET_TURNSTILE_SECRET=...
# FAUCET_HCAPTCHA_SITE_KEY=...
# FAUCET_HCAPTCHA_SECRET=...
# FCaptcha: self-hosted alternative. Deploy via deploy/compose/fcaptcha.yml.
# FAUCET_FCAPTCHA_URL=http://fcaptcha:3000
# FAUCET_FCAPTCHA_SITE_KEY=...
# FAUCET_FCAPTCHA_SECRET=...

# --- Self-hosted hashcash client puzzle (optional fallback / standalone) ---
# Client-side SHA-256 anti-bot challenge; unrelated to Nimiq's proof-of-stake consensus.
# Set a long random string to enable. Difficulty = leading zero bits (20 ~= 1M hashes).
# FAUCET_HASHCASH_SECRET=at-least-16-chars-long-random-string
# FAUCET_HASHCASH_DIFFICULTY=20
# FAUCET_HASHCASH_TTL_MS=300000

# --- Geo-IP / ASN / VPN / datacenter filtering ---
# Backend: "dbip" (default, built-in DB-IP Lite — no config needed),
#          "maxmind" (offline .mmdb — needs license key),
#          "ipinfo" (API — needs token), or "none" (off).
# FAUCET_GEOIP_BACKEND=dbip
# FAUCET_GEOIP_MAXMIND_COUNTRY_DB=/data/geoip/GeoLite2-Country.mmdb
# FAUCET_GEOIP_MAXMIND_ASN_DB=/data/geoip/GeoLite2-ASN.mmdb
# FAUCET_GEOIP_IPINFO_TOKEN=...
#
# Country policy (ISO alpha-2, comma-separated). Deny takes precedence over allow.
# Allow-list: any other country is denied when this is set.
# FAUCET_GEOIP_DENY_COUNTRIES=KP,IR,SY
# FAUCET_GEOIP_ALLOW_COUNTRIES=
# FAUCET_GEOIP_DENY_ASNS=             # comma-separated ASN numbers
# FAUCET_GEOIP_DENY_VPN=false         # denies when ASN org matches VPN heuristic
# FAUCET_GEOIP_DENY_TOR=false
# FAUCET_GEOIP_DENY_HOSTING=false     # denies common hosting providers (AWS, DO, etc.)

# --- Admin & dashboard ---
FAUCET_ADMIN_PASSWORD=change-me-at-least-8-chars
# FAUCET_ADMIN_TOTP_SECRET=... (generated on first login if absent; provisioning URI returned once)
# FAUCET_ADMIN_SESSION_TTL_MS=28800000         # 8h default session cookie lifetime
# FAUCET_ADMIN_TOTP_STEP_UP_TTL_MS=120000      # 2m default sensitive-action TOTP re-auth window
# FAUCET_KEYRING_PATH=/data/faucet.key         # XChaCha20-Poly1305 encrypted key blob (argon2id/scrypt KDF)

# --- Integrator keys (server-to-server HMAC) ---
# Comma-separated "<id>:<apiKey>:<hmacSecret>" triples.
# FAUCET_INTEGRATOR_KEYS=demo:key_abc123:secret_xyz789

# --- Storage ---
FAUCET_DATA_DIR=/data
# DATABASE_URL is intentionally empty: server uses SQLite at $FAUCET_DATA_DIR/faucet.db.
# Postgres support is planned — see ROADMAP.md 1.3.x. Setting
# DATABASE_URL=postgres://... today will fail startup with a clear error.
# DATABASE_URL=sqlite:///data/faucet.db            # explicit form of the default
# REDIS_URL is intentionally empty: in-memory rate-limit counters.
# REDIS_URL=redis://localhost:6379                 # planned, not yet consumed

# --- Misc ---
FAUCET_CORS_ORIGINS=*               # "*" or comma-separated list
FAUCET_DEV=false

# --- Security hardening ---
# In production TLS is required — the server refuses to start on plain HTTP
# unless FAUCET_DEV=1. Set FAUCET_TLS_REQUIRED=false explicitly to allow HTTP.
# FAUCET_TLS_REQUIRED=true
# FAUCET_HELMET_CSP=relaxed-for-ui      # strict | relaxed-for-ui | off
