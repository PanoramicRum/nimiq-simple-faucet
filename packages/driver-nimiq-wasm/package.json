{
  "name": "@faucet/driver-nimiq-wasm",
  "version": "0.0.1",
  "private": true,
  "description": "CurrencyDriver implementation that signs and broadcasts Nimiq transactions using the Nimiq Web Client (WASM). No external node required.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@faucet/core": "workspace:*",
    "@nimiq/core": "^2.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
