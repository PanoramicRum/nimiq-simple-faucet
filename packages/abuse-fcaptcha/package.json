{
  "name": "@faucet/abuse-fcaptcha",
  "version": "0.0.1",
  "private": true,
  "description": "FCaptcha token verification as an AbuseCheck. Thin driver over the self-hosted FCaptcha service (https://github.com/WebDecoy/FCaptcha).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@faucet/core": "workspace:*",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
