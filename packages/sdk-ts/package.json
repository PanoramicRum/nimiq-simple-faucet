{
  "name": "@nimiq-faucet/sdk",
  "version": "0.0.1",
  "description": "Framework-agnostic client for the Nimiq Simple Faucet. Works in browser and Node.",
  "license": "MIT",
  "author": "Nimiq <richy@nimiq.com>",
  "repository": { "type": "git", "url": "https://github.com/PanoramicRum/nimiq-simple-faucet.git", "directory": "packages/sdk-ts" },
  "homepage": "https://github.com/PanoramicRum/nimiq-simple-faucet/tree/main/packages/sdk-ts#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "keywords": ["nimiq", "faucet", "crypto", "sdk"],
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
