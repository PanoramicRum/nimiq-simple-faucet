{
  "name": "@nimiq-faucet/sdk",
  "version": "0.0.1",
  "description": "Framework-agnostic client for the Nimiq Simple Faucet. Works in browser and Node.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "keywords": ["nimiq", "faucet", "crypto", "sdk"],
  "devDependencies": {
    "typescript": "^5.6.2"
  }
}
