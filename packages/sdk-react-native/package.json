{
  "name": "@nimiq-faucet/react-native",
  "version": "0.0.1",
  "description": "React Native integration for the Nimiq Simple Faucet. Auto-populates fingerprint from react-native-device-info.",
  "license": "MIT",
  "author": "Nimiq <richy@nimiq.com>",
  "repository": { "type": "git", "url": "https://github.com/PanoramicRum/nimiq-simple-faucet.git", "directory": "packages/sdk-react-native" },
  "homepage": "https://github.com/PanoramicRum/nimiq-simple-faucet/tree/main/packages/sdk-react-native#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "react-native": ">=0.74",
    "react-native-device-info": ">=11"
  },
  "dependencies": {
    "@nimiq-faucet/sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "keywords": ["nimiq", "faucet", "react-native", "mobile"]
}
