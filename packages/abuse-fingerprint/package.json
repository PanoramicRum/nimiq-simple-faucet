{
  "name": "@faucet/abuse-fingerprint",
  "version": "0.0.1",
  "private": true,
  "description": "Correlate client fingerprint visitor IDs with host-provided uids / cookie hashes to detect multi-browser or multi-account farming.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@faucet/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^2.1.2"
  }
}
