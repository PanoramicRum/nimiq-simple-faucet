{
  "name": "@faucet/abuse-geoip",
  "version": "0.0.1",
  "private": true,
  "description": "Geo-IP / ASN / VPN / datacenter abuse check with pluggable resolvers (MaxMind GeoLite2 and IPinfo).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@faucet/core": "workspace:*",
    "@ip-location-db/dbip-asn-mmdb": "^2.3.2026040119",
    "@ip-location-db/dbip-country-mmdb": "^2.3.2026040119",
    "maxmind": "^5.0.6",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^2.1.2"
  }
}
