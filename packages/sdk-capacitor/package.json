{
  "name": "@nimiq-faucet/capacitor",
  "version": "0.0.1",
  "description": "Capacitor integration for the Nimiq Simple Faucet. Auto-populates fingerprint from Device.getId().",
  "license": "MIT",
  "author": "Nimiq <richy@nimiq.com>",
  "repository": { "type": "git", "url": "https://github.com/PanoramicRum/nimiq-simple-faucet.git", "directory": "packages/sdk-capacitor" },
  "homepage": "https://github.com/PanoramicRum/nimiq-simple-faucet/tree/main/packages/sdk-capacitor#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/device": "^7.0.0"
  },
  "dependencies": {
    "@nimiq-faucet/sdk": "workspace:*"
  },
  "devDependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/device": "^7.0.0",
    "typescript": "^5.6.2"
  },
  "keywords": ["nimiq", "faucet", "capacitor", "mobile"]
}
