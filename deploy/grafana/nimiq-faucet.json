{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Nimiq Simple Faucet",
  "uid": "nimiq-faucet",
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "title": "Claim Rate (5m)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(faucet_claims_total[5m]))",
          "legendFormat": "claims/s",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Wallet Balance (NIM)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "faucet_wallet_balance_luna / 100000",
          "legendFormat": "NIM",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 2 } }
    },
    {
      "title": "Driver Ready",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "faucet_driver_ready",
          "legendFormat": "ready",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NOT READY", "color": "red" }, "1": { "text": "READY", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "Wallet Balance (luna) — timeseries",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "faucet_wallet_balance_luna",
          "legendFormat": "balance (luna)",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "title": "Claims by Status + Decision",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (status, decision) (rate(faucet_claims_total[5m]))",
          "legendFormat": "{{status}} / {{decision}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30 } } }
    },
    {
      "title": "Claim Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(faucet_claim_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(faucet_claim_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(faucet_claim_duration_seconds_bucket{phase=\"total\"}[5m])))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Reconciler Flips",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (to) (rate(faucet_reconciler_flips_total[5m]))",
          "legendFormat": "→ {{to}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "schemaVersion": 39
}
