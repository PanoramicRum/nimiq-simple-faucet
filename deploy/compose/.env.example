# Copy to `.env` next to docker-compose.yml, then edit the two required
# values below (FAUCET_ADMIN_PASSWORD + wallet). See README.md for the
# two supported modes (external RPC vs. local `core-rs-albatross` node).

# Which network the faucet runs against. `test` or `main`.
FAUCET_NETWORK=test

# Signer driver: `rpc` (external / local node) or `wasm` (in-process).
#   - `rpc`:  recommended. Works with either an external Albatross JSON-RPC
#             endpoint OR the local-node profile (see below).
#   - `wasm`: in-process light client. Currently cannot reach TestAlbatross
#             consensus — tracked upstream as #35. Avoid until resolved.
FAUCET_SIGNER_DRIVER=rpc

# ============================================================================
# REQUIRED: admin + key encryption
# ============================================================================

# Admin dashboard password (hashed on first boot). CHANGE THIS before booting.
FAUCET_ADMIN_PASSWORD=change-me

# Passphrase used to encrypt the faucet key blob at rest in `faucet-data`.
FAUCET_KEY_PASSPHRASE=change-me-too

# Local-trial mode: relaxes server hardening (allows plain HTTP + wildcard
# CORS) so the compose stack works against http://localhost:8080. REMOVE
# this line (or set to 0) when promoting this .env to a TLS-fronted
# deployment — the server refuses to start with FAUCET_CORS_ORIGINS=* and
# FAUCET_TLS_REQUIRED=true otherwise.
FAUCET_DEV=1

# ============================================================================
# Wallet setup — pick ONE of the two flows below
# ============================================================================

# --- Flow A: Bring your own funded wallet -----------------------------------
# If you already have a testnet address with NIM and know its private key:
#
#   FAUCET_WALLET_ADDRESS=NQ00 0000 0000 0000 0000 0000 0000 0000 0000
#   FAUCET_PRIVATE_KEY=<64-char hex OR 12/24-word mnemonic>

# --- Flow B: Generate a fresh wallet locally and fund it --------------------
# From the repo root:
#   pnpm generate:wallet
# This writes `.wallet.local.json` (gitignored) with a fresh address + key.
# Fund the printed address at https://faucet.pos.nimiq-testnet.com, then copy
# the values into FAUCET_WALLET_ADDRESS and FAUCET_PRIVATE_KEY below.

FAUCET_WALLET_ADDRESS=NQ00 0000 0000 0000 0000 0000 0000 0000 0000
# FAUCET_PRIVATE_KEY=<paste from .wallet.local.json>

# ============================================================================
# RPC endpoint (FAUCET_SIGNER_DRIVER=rpc)
# ============================================================================

# Leave unset to use the local `core-rs-albatross` node started by the
# `local-node` profile (answers at http://nimiq:8648 on the compose network).
# Set to an external endpoint to skip the local-node profile.
# FAUCET_RPC_URL=https://your-albatross-testnet-rpc.example

# ============================================================================
# Postgres credentials — ONLY used by the `postgres` profile.
# ============================================================================
# The default compose stack runs SQLite in the `faucet-data` volume.
# Postgres + Redis are defined in docker-compose.yml but gated behind
# the `postgres` profile and are NOT yet consumed by the server (see
# ROADMAP.md 1.3.x). Change these before enabling the profile in
# production, once server-side Postgres lands.
POSTGRES_USER=faucet
POSTGRES_PASSWORD=faucet
POSTGRES_DB=faucet
