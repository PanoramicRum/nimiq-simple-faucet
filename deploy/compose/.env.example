# Copy to `.env` next to docker-compose.yml.
# See README.md for the two supported modes (external RPC vs. local node).

# Which network the faucet runs against. `test` or `main`.
FAUCET_NETWORK=test

# Signer driver: `rpc` (external / local node) or `wasm` (in-process).
#   - `rpc`:  faucet calls an external Nimiq Albatross JSON-RPC node which
#             holds the unlocked wallet.
#   - `wasm`: faucet signs in-process using a private key supplied below.
#             Simpler for smoke tests — no local node to configure.
FAUCET_SIGNER_DRIVER=wasm

# ============================================================================
# Wallet setup — pick ONE of the two flows below
# ============================================================================

# --- Flow A: Bring your own funded wallet -----------------------------------
# If you already have a testnet address with NIM and know its private key,
# just set the two values below and you're done.
#
#   FAUCET_WALLET_ADDRESS=NQ00 0000 0000 0000 0000 0000 0000 0000 0000
#   FAUCET_PRIVATE_KEY=<64-char hex OR 12/24-word mnemonic>

# --- Flow B: Generate a fresh wallet locally and fund it --------------------
# From the repo root:
#   pnpm generate:wallet
# This writes `.wallet.local.json` (gitignored) with a fresh address + key.
# Fund the printed address at https://faucet.pos.nimiq-testnet.com then copy
# the values into FAUCET_WALLET_ADDRESS and FAUCET_PRIVATE_KEY below.

FAUCET_WALLET_ADDRESS=NQ00 0000 0000 0000 0000 0000 0000 0000 0000
# FAUCET_PRIVATE_KEY=<paste from .wallet.local.json>

# ============================================================================
# Only needed for FAUCET_SIGNER_DRIVER=rpc
# ============================================================================

# Set to an external Albatross endpoint, OR leave unset and start compose with
# `docker compose --profile local-node up -d` to run your own node (which
# answers at `http://nimiq:8648`).
# FAUCET_RPC_URL=https://your-albatross-testnet-rpc.example

# ============================================================================
# Admin + key encryption (always required)
# ============================================================================

# Admin dashboard password (will be hashed on first boot).
FAUCET_ADMIN_PASSWORD=change-me

# Passphrase used to encrypt the faucet key blob at rest in `faucet-data`.
FAUCET_KEY_PASSPHRASE=change-me-too

# ============================================================================
# Postgres credentials — IMPORTANT: change these in production!
# ============================================================================
POSTGRES_USER=faucet
POSTGRES_PASSWORD=faucet
POSTGRES_DB=faucet
