{
  "name": "@faucet/server",
  "version": "0.0.1",
  "private": true,
  "description": "Nimiq Simple Faucet server: Fastify + Zod + Drizzle, REST + WS + MCP + admin API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "FAUCET_GEOIP_BACKEND=none vitest run",
    "freeze:openapi": "tsx scripts/freeze-openapi.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@fastify/cookie": "^11.0.1",
