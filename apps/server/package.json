    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.0.1",
    "@faucet/abuse-ai": "workspace:*",
    "@faucet/abuse-fingerprint": "workspace:*",
    "@faucet/abuse-geoip": "workspace:*",
    "@faucet/abuse-hashcash": "workspace:*",
    "@faucet/abuse-hcaptcha": "workspace:*",
    "@faucet/abuse-onchain-nimiq": "workspace:*",
    "@faucet/core": "workspace:*",
    "@faucet/driver-nimiq-rpc": "workspace:*",
    "@faucet/driver-nimiq-wasm": "workspace:*",
