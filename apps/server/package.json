    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "undici": "^8.1.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
