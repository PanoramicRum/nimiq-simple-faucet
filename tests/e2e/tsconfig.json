{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "composite": false,
    "declaration": false,
    "sourceMap": true,
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "types": ["node"],
    "skipLibCheck": true
